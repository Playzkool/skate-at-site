---
import Layout from '../../layouts/Layout.astro'
import { CONTACT_EMAIL, SITE_NAME } from '../../consts'

const faqs = [
  {
    q: 'How do I sign in to SkateAT?',
    a: `${SITE_NAME} uses your Bluesky / AT Protocol account. On the sign-in screen, enter your Bluesky handle (e.g. yourname.bsky.social) and an app password — not your main password. You can generate an app password at bsky.app → Settings → App passwords.`,
  },
  {
    q: "I don't have a Bluesky account. Can I still use SkateAT?",
    a: 'You need a free AT Protocol account to use the app. The easiest way is to create one at bsky.social — it\'s free and takes about a minute. You can also use any other compatible AT Protocol PDS.',
  },
  {
    q: 'How do I delete my account or my data?',
    a: `Your spots, sessions, tricks and media are stored in your own AT Protocol repo (on Bluesky's servers or your own PDS). You can delete them directly from the app or from your Bluesky account. To request deletion of any data held by ${SITE_NAME}'s server (push notification token, preferences), email us at the address below.`,
  },
  {
    q: 'The app is asking for my location — why?',
    a: 'Location is used only to center the map and show nearby spots. It is processed entirely on your device and is never sent to our servers.',
  },
  {
    q: 'How do tips work? What do I get?',
    a: `Tips are voluntary one-time purchases made via Apple In-App Purchase. They don't unlock any features — ${SITE_NAME} is and will remain completely free. A small supporter badge is shown on your profile as a thank-you. Tips go directly towards hosting and development costs.`,
  },
  {
    q: 'I purchased a tip but nothing happened.',
    a: 'If your purchase was charged but the supporter badge did not appear, please email us with your handle and the date of purchase and we will sort it out.',
  },
  {
    q: 'I found a bug or the app crashed.',
    a: 'Please email us with a short description of what happened (screen you were on, what you tapped, what you expected vs. what occurred). Screenshots are very helpful.',
  },
]
---

<Layout
  title="Support"
  description={`Get help with ${SITE_NAME}: frequently asked questions and contact information.`}
  lang="en"
  path="support/"
>
  <h1>Support</h1>
  <p class="intro">
    Something not working? Have a question? Check the FAQ below — if you can't find your answer,
    drop us an email and we'll get back to you.
  </p>

  <section class="faq">
    {
      faqs.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))
    }
  </section>

  <section class="contact">
    <h2>Contact</h2>
    <p>
      Can't find an answer above? Email us at{' '}
      <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a> — we aim to reply within 48 hours.
    </p>
  </section>
</Layout>

<style>
  .intro {
    color: var(--secondary-text);
    font-size: 1rem;
    margin-bottom: 32px;
  }

  .faq {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 48px;
  }

  details {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0;
    overflow: hidden;
  }

  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.975rem;
    padding: 16px 18px;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '+';
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--secondary-text);
    flex-shrink: 0;
  }

  details[open] summary::after {
    content: '−';
  }

  details p {
    margin: 0;
    padding: 0 18px 16px;
    color: var(--secondary-text);
    font-size: 0.93rem;
    line-height: 1.6;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  .contact h2 {
    margin-top: 0;
  }
</style>